generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id              String   @id @default(cuid())
  name            String?
  phone           String?  @unique
  role            String   @default("GENERATOR")
  reputation      Int      @default(0)
  points          Int      @default(0)
  createdAt       DateTime @default(now())
  createdWastePins WastePin[] @relation("CreatedByUser")
  claimedWastePins WastePin[] @relation("ClaimedByUser")
}

model WastePin {
  id          String   @id @default(cuid())
  title       String
  description String?
  latitude    Float
  longitude   Float
  wasteType   String
  quantity    String
  photos      String?
  contact     String?
  status      String   @default("OPEN")
  creator     User?    @relation("CreatedByUser", fields: [creatorId], references: [id])
  creatorId   String?
  claimedBy   User?    @relation("ClaimedByUser", fields: [claimedById], references: [id])
  claimedById String?
  claimedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
}
