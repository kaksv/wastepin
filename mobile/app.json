{
  "expo": {
    "name": "WastePin",
    "slug": "wastepin",
    "version": "1.0.0",
    "sdkVersion": "48.0.0",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2f6ef4"
    },
    "android": {
      "package": "com.wastepin.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2f6ef4"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "WastePin needs location to pin waste collection points."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "WastePin needs photo access to attach images to waste pins."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "af8b55d9-ec2f-4963-8500-bbb472097937"
      }
    },
    "owner": "kakoozavian"
  }
}
